<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sandbox off: the app manages mod files in arbitrary game folders
	     (e.g. under ~/Documents), which the sandbox forbids. Developer ID
	     (non-App-Store) distribution does not require sandboxing. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
</dict>
</plist>
